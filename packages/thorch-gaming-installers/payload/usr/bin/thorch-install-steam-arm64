#!/usr/bin/env bash
set -euo pipefail

assume_yes=0
while [[ $# -gt 0 ]]; do
  case "$1" in
    -y|--yes)
      assume_yes=1
      ;;
    *)
      echo "usage: thorch-install-steam-arm64 [--yes]" >&2
      exit 2
      ;;
  esac
  shift
done

cat <<'EOF'
This installer does not ship Steam. It downloads Valve's Linux ARM64 client
into the installing user's home directory and installs local launch helpers.

You are responsible for complying with Valve's Steam license terms.
EOF

if [[ "${assume_yes}" -ne 1 ]]; then
  printf 'Type STEAM to install the launcher: '
  read -r answer
  [[ "${answer}" == "STEAM" ]] || { echo "aborted"; exit 1; }
fi

if [[ "${EUID}" -eq 0 ]]; then
  echo "Run this as the desktop user so Steam installs into that user's home directory." >&2
  exit 1
fi

for cmd in curl file wget unzip strings; do
  command -v "${cmd}" >/dev/null 2>&1 || {
    echo "Missing ${cmd}. Install curl, file, wget, unzip, and binutils first." >&2
    exit 1
  }
done
bin_dir="${HOME}/.local/bin"
app_dir="${HOME}/.local/share/applications"
install -d "${bin_dir}" "${app_dir}"

install_steam_launcher() {
  local launcher_source setup_source

  setup_source="${THORCH_STEAM_SETUP_SOURCE:-/usr/bin/thorch-setup-steam-arm64}"
  launcher_source="${THORCH_STEAM_LAUNCHER_SOURCE:-/usr/bin/thorch-start-steam-arm64}"
  if [[ ! -x "${setup_source}" ]]; then
    echo "Missing ${setup_source}; install the thorch-gaming-installers package first." >&2
    exit 1
  fi
  if [[ ! -x "${launcher_source}" ]]; then
    echo "Missing ${launcher_source}; install the thorch-gaming-installers package first." >&2
    exit 1
  fi

  if [[ "$(readlink -f "${setup_source}")" != "$(readlink -m "${bin_dir}/thorch-setup-steam-arm64")" ]]; then
    install -m 0755 "${setup_source}" "${bin_dir}/thorch-setup-steam-arm64"
  fi
  if [[ "$(readlink -f "${launcher_source}")" != "$(readlink -m "${bin_dir}/thorch-start-steam-arm64")" ]]; then
    install -m 0755 "${launcher_source}" "${bin_dir}/thorch-start-steam-arm64"
  fi
}

install_steam_launcher
"${bin_dir}/thorch-setup-steam-arm64"

rm -f \
  "${bin_dir}/thorch-start-steam-arm64-gamescope" \
  "${bin_dir}/thorch-start-steam-arm64-deck" \
  "${app_dir}/thorch-steam-arm64-gamescope.desktop" \
  "${app_dir}/thorch-steam-arm64-deck.desktop"

cat > "${app_dir}/thorch-steam-arm64.desktop" <<EOF
[Desktop Entry]
Type=Application
Name=Steam
Comment=Launch Steam
Exec=${bin_dir}/thorch-start-steam-arm64
Icon=steam
Terminal=false
Categories=Game;
EOF

echo "Installed ${bin_dir}/thorch-start-steam-arm64"
