# KDE/KWin maps absolute touch devices to a single output when WL_OUTPUT is set.
# Runtime calibration is applied by thorch-kwin-touch-map using KWin DBus.
SUBSYSTEM=="input", KERNEL=="event*", ENV{ID_INPUT_TOUCHSCREEN}=="1", ENV{ID_PATH}=="platform-a90000.i2c", ENV{WL_OUTPUT}="DSI-2"
SUBSYSTEM=="input", KERNEL=="event*", ENV{ID_INPUT_TOUCHSCREEN}=="1", ENV{ID_PATH}=="platform-98c000.i2c", ENV{WL_OUTPUT}="DSI-1"
