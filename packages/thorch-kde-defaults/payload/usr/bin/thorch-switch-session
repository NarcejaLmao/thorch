#!/usr/bin/env bash
set -euo pipefail

usage() {
  echo "usage: thorch-switch-session desktop|mobile|steamos|steamos-mobile|steamos-desktop" >&2
  exit 2
}

[[ $# -eq 1 ]] || usage

mode="$1"
case "${mode}" in
  desktop|mobile|steamos|steamos-mobile|steamos-desktop) ;;
  *) usage ;;
esac

if [[ "${EUID}" -ne 0 ]]; then
  if command -v pkexec >/dev/null 2>&1; then
    exec pkexec /usr/bin/thorch-sessionctl set "${mode}" --reboot
  fi
  exec sudo /usr/bin/thorch-sessionctl set "${mode}" --reboot
fi

exec /usr/bin/thorch-sessionctl set "${mode}" --reboot
