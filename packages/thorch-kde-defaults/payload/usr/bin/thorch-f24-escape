#!/usr/bin/env python3
import os
import struct
import subprocess
import time
import configparser

EV_KEY = 1
KEY_F24 = 194
DEBOUNCE_SECONDS = 0.35


def thorch_user():
    env_user = os.environ.get("THORCH_USER")
    if env_user:
        return env_user

    parser = configparser.ConfigParser()
    for path in ("/etc/sddm.conf.d/10-thorch.conf", "/etc/sddm.conf"):
        try:
            parser.read(path)
        except configparser.Error:
            continue
        if parser.has_option("Autologin", "User"):
            return parser.get("Autologin", "User").strip() or "thorch"
    return "thorch"


USER = thorch_user()


def find_gpio_keys():
    for name in sorted(os.listdir("/sys/class/input")):
        if not name.startswith("event"):
            continue
        path = f"/sys/class/input/{name}/device/name"
        try:
            with open(path, "r", encoding="utf-8") as f:
                devname = f.read().strip()
        except OSError:
            continue
        if devname == "gpio-keys":
            return f"/dev/input/{name}"
    return "/dev/input/event6"


def show_desktop():
    home = f"/home/{USER}"
    try:
        uid = os.stat(home).st_uid
    except OSError:
        return
    qdbus = "/usr/bin/qdbus6" if os.path.exists("/usr/bin/qdbus6") else "/usr/bin/qdbus"
    env = os.environ.copy()
    env.update({
        "HOME": home,
        "XDG_RUNTIME_DIR": f"/run/user/{uid}",
        "DBUS_SESSION_BUS_ADDRESS": f"unix:path=/run/user/{uid}/bus",
    })
    subprocess.run([
        "runuser", "-u", USER, "--", qdbus,
        "org.kde.KWin", "/KWin", "org.kde.KWin.showDesktop", "true",
    ], env=env, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False)


dev = find_gpio_keys()
fmt = "llHHi"
size = struct.calcsize(fmt)
last = 0.0

while True:
    try:
        with open(dev, "rb", buffering=0) as f:
            while True:
                data = f.read(size)
                if len(data) != size:
                    break
                _, _, etype, code, value = struct.unpack(fmt, data)
                if etype == EV_KEY and code == KEY_F24 and value == 1:
                    now = time.monotonic()
                    if now - last >= DEBOUNCE_SECONDS:
                        last = now
                        show_desktop()
    except OSError:
        time.sleep(1)
