#!/usr/bin/env bash
set -euo pipefail

for _ in $(seq 1 20); do
  [[ -e /sys/class/net/usb0 ]] && break
  sleep 1
done

[[ -e /sys/class/net/usb0 ]] || exit 0

ip addr replace 10.66.0.1/24 dev usb0 || true
ip link set dev usb0 up || true

if [[ -s /run/thorch-usb-dnsmasq.pid ]]; then
  kill "$(cat /run/thorch-usb-dnsmasq.pid)" 2>/dev/null || true
fi
pkill -f 'dnsmasq .*--dhcp-range=interface:usb0,10\.66\.0\.' 2>/dev/null || true
rm -f /run/thorch-usb-dnsmasq.pid

dnsmasq \
  --conf-file=/dev/null \
  --pid-file=/run/thorch-usb-dnsmasq.pid \
  --bind-interfaces \
  --interface=usb0 \
  --listen-address=10.66.0.1 \
  --dhcp-authoritative \
  --dhcp-range=interface:usb0,10.66.0.10,10.66.0.30,255.255.255.0,1h
