#!/usr/bin/env bash
set -euo pipefail

state_dir="${THORCH_QUICKSETTING_STATE_DIR:-/var/lib/thorch/quicksettings}"
systemctl_cmd="${THORCH_QUICKSETTING_SYSTEMCTL:-systemctl}"
rgb_cmd="${THORCH_QUICKSETTING_RGB:-/usr/bin/thorch-rgb}"
hardware_cmd="${THORCH_QUICKSETTING_HARDWARECTL:-/usr/bin/thorch-hardwarectl}"

usage() {
  cat >&2 <<'EOF'
usage:
  thorch-quicksetting-toggle usb|ssh|rgb status
  thorch-quicksetting-toggle usb|ssh|rgb toggle
EOF
  exit 2
}

run_systemctl() {
  "${systemctl_cmd}" "$@"
}

service_is_active() {
  run_systemctl is-active --quiet "$1"
}

print_service_status() {
  if service_is_active "$1"; then
    printf 'on\n'
  else
    printf 'off\n'
  fi
}

require_root_for_toggle() {
  local target="$1" action="$2"

  [[ "${action}" == "toggle" ]] || return 0
  [[ "${EUID}" -eq 0 ]] && return 0
  [[ "${THORCH_QUICKSETTING_SKIP_PKEXEC:-0}" == "1" ]] && return 0

  if command -v pkexec >/dev/null 2>&1; then
    exec pkexec /usr/bin/thorch-quicksetting-toggle "${target}" "${action}"
  fi

  exec sudo /usr/bin/thorch-quicksetting-toggle "${target}" "${action}"
}

disable_services() {
  run_systemctl stop "$@" >/dev/null 2>&1 || true
  run_systemctl disable "$@"
}

enable_services() {
  local service

  run_systemctl enable "$@"
  for service in "$@"; do
    run_systemctl start "${service}"
  done
}

toggle_usb() {
  if service_is_active thorch-usb-gadget.service; then
    disable_services thorch-usb-network.service thorch-usb-gadget.service
  else
    enable_services thorch-usb-gadget.service thorch-usb-network.service
  fi
}

toggle_ssh() {
  if service_is_active sshd.service; then
    disable_services sshd.service
  else
    enable_services sshd.service
  fi
}

rgb_status_output() {
  "${rgb_cmd}" status
}

rgb_mode() {
  rgb_status_output | awk '/^mode: / { print $2; found = 1; exit } END { if (!found) exit 1 }'
}

rgb_static_values() {
  rgb_status_output | awk '/^static: / { print $2, $3, $4; found = 1; exit } END { if (!found) exit 1 }'
}

print_rgb_status() {
  if [[ "$(rgb_mode)" == "off" ]]; then
    printf 'off\n'
  else
    printf 'on\n'
  fi
}

save_rgb_mode() {
  local mode="$1"

  install -d -m 0755 "${state_dir}"
  printf '%s\n' "${mode}" > "${state_dir}/rgb-mode"
}

restore_rgb_mode() {
  local mode red green blue

  mode="$(cat "${state_dir}/rgb-mode" 2>/dev/null || true)"
  case "${mode}" in
    battery|static) ;;
    *) mode="battery" ;;
  esac

  case "${mode}" in
    battery)
      "${hardware_cmd}" set rgb-mode battery
      ;;
    static)
      read -r red green blue < <(rgb_static_values)
      "${hardware_cmd}" set rgb-color "${red}" "${green}" "${blue}"
      ;;
  esac
}

toggle_rgb() {
  local mode

  mode="$(rgb_mode)"
  if [[ "${mode}" == "off" ]]; then
    restore_rgb_mode
  else
    save_rgb_mode "${mode}"
    "${hardware_cmd}" set rgb-mode off
  fi
}

target="${1:-}"
action="${2:-}"

case "${target}:${action}" in
  usb:status)
    print_service_status thorch-usb-gadget.service
    ;;
  usb:toggle)
    require_root_for_toggle "${target}" "${action}"
    toggle_usb
    ;;
  ssh:status)
    print_service_status sshd.service
    ;;
  ssh:toggle)
    require_root_for_toggle "${target}" "${action}"
    toggle_ssh
    ;;
  rgb:status)
    print_rgb_status
    ;;
  rgb:toggle)
    require_root_for_toggle "${target}" "${action}"
    toggle_rgb
    ;;
  *)
    usage
    ;;
esac
